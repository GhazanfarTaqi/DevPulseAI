# ==========================================
# Global / Root Rules
# ==========================================
.DS_Store
Thumbs.db
.env
.env.*
.env.local
*.log

# ==========================================
# Next.js Frontend Rules (frontend/)
# ==========================================

# Dependencies
frontend/node_modules/
frontend/.pnp
frontend/.pnp.*
frontend/.yarn/*
!frontend/.yarn/patches
!frontend/.yarn/plugins
!frontend/.yarn/releases
!frontend/.yarn/versions

# Testing & Builds
frontend/coverage/
frontend/.next/
frontend/out/
frontend/build/

# Vercel & TS
frontend/.vercel/
frontend/*.tsbuildinfo
frontend/next-env.d.ts
frontend/*.pem

# Debug logs
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/.pnpm-debug.log*


# ==========================================
# FastAPI Machine Learning Backend Rules (backend/)
# ==========================================

# Virtual Environments (Crucial to ignore!)
backend/venv/
backend/env/
backend/.venv/
backend/ENV/

# Python bytecode & cache
backend/__pycache__/
backend/*.py[cod]
backend/*$py.class
backend/.pytest_cache/
backend/.mypy_cache/

# Machine Learning specific (Large weights/datasets)
# Un-comment these if you store models or data inside the backend folder
# backend/models/*.pkl
# backend/models/*.h5
# backend/models/*.pt
# backend/data/*.csv

# Project-level configurations
backend/.idea/
backend/.vscode/